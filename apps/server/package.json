  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "tsx app.ts",
    "dev": "tsx watch app.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "supabase:ping": "tsx supabase/ping.ts",
