{
  "version": 2,
  "installCommand": "corepack enable && corepack prepare pnpm@10.28.2 --activate && pnpm install --frozen-lockfile",
  "builds": [
    {
      "src": "app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "uploads/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.ts"
    }
  ]
}
