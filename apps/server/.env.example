DB_HOST=domain_name
DB_USER=username_of_database
DB_PASS=password_of_database
DB_NAME=digital_portfolio_system
DB_PROVIDER=supabase
SUPABASE_ONLY=true

EMAIL_USER=email_of_the_system
EMAIL_PASS=password_of_the_system

JWT_SECRET=random_characters

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# Required in production so CORS allows the deployed web app URL.
CLIENT_ORIGIN=

# Optional comma-separated additional allowed origins.
# Example: https://digital-portfolio-system-web.vercel.app,https://digital-portfolio-system-server.vercel.app
ALLOWED_ORIGINS=

# Admin allowlist (comma-separated). At least one should be set.
# Only teacher accounts listed here can access /admin endpoints and page.
ADMIN_EMAILS=
ADMIN_USERNAMES=
ADMIN_USER_IDS=