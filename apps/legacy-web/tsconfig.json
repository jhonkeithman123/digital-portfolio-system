{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "components/*": ["components/*"],
      "hooks/*": ["hooks/*"],
      "utils/*": ["utils/*"],
      "types/*": ["types/*"],
      "security/*": ["security/*"],
      "pages/*": ["pages/*"],
      "classroom/*": ["pages/classrooms/*"],
      "dash/*": ["pages/Dashboard/*"],
      "forgot/*": ["pages/ForgotPassword/*"],
      "home/*": ["pages/Home/*"],
      "login/*": ["pages/Login/*"],
      "notFound/*": ["pages/NotFound/*"],
      "roleSelect/*": ["pages/RoleSelect/*"],
      "signup/*": ["pages/Signup/*"]
    }
  },
  "include": ["src", "src/types/**/*.d.ts", "src/types/**/*.ts"]
}
