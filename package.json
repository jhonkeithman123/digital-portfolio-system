{
  "name": "client-vite",
  "private": true,
  "version": "1.2.0",
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel --ui=tui --filter=@digital-portfolio/server --filter=@digital-portfolio/web --filter=@digital-portfolio/legacy-web",
    "dev:web": "pnpm --filter @digital-portfolio/web dev",
    "dev:legacy": "pnpm --filter @digital-portfolio/legacy-web legacy:dev",
    "dev:server": "pnpm --filter @digital-portfolio/server dev",
    "build": "turbo run build --ui=tui",
    "clean": "node scripts/clean.mjs",
    "clean:standard": "node scripts/clean.mjs --standard",
    "clean:deep": "node scripts/clean.mjs --deep",
    "reinstall": "pnpm clean && pnpm install --force",
    "lint": "turbo run lint",
    "lint-fix": "eslint --fix .",
    "typecheck": "turbo run typecheck",
    "deploy": "npx gh-pages -d apps/web/out"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "turbo": "^2.5.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
